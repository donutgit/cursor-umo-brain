{
  "mcpServers": {
    "david-brain": {
      "url": "${BRAIN_MCP_URL:-http://localhost:5053/mcp}",
      "headers": {
        "x-api-key": "${BRAIN_MCP_API_KEY}"
      }
    },
    "gitlab": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-gitlab"],
      "env": {
        "GITLAB_PERSONAL_ACCESS_TOKEN": "${GITLAB_TOKEN}",
        "GITLAB_API_URL": "${GITLAB_API_URL:-https://gitlab.umo.tech/api/v4}"
      }
    }
  }
}
